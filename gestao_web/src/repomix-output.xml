.data-value { font-size: 15px; color: var(--txt); padding: 11px 0; border-bottom: 1px solid var(--bg); font-weight: 500; }

.alert-overdue { background: var(--alrt-bg); border: 1px solid var(--alrt-br); border-radius: var(--r); padding: 20px 24px; margin-bottom: 20px; display: flex; gap: 16px; align-items: flex-start; }
