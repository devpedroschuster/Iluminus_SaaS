.alert-overdue-text { font-size: 13px; color: #7F1D1D; line-height: 1.65; margin-bottom: 14px; }

.stats-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-bottom: 20px; }
.stat-card { background: var(--white); border: 1px solid var(--border); border-radius: var(--r); padding: 20px 22px; }
.stat-card-label { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); margin-bottom: 10px; }
.stat-card-value { font-family: var(--font-display); font-size: 28px; font-weight: 900; line-height: 1; }
.stat-card-sub { font-size: 12px; color: var(--muted); margin-top: 4px; }

.pay-table-wrapper { overflow-x: auto; }
