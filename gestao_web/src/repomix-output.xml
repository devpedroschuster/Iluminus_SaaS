/* ... o resto do CSS permanece igualzinho ... */
.day-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; }
.day-tab { padding: 10px 22px; border-radius: var(--r-sm); border: 1.5px solid var(--border); font-family: var(--font-body); font-size: 13px; font-weight: 700; color: var(--muted); cursor: pointer; background: var(--white); transition: all .18s; }
.day-tab:hover { border-color: var(--pri-l); color: var(--txt); }
.day-tab.active { background: var(--pri); border-color: var(--pri); color: #fff; box-shadow: 0 4px 12px rgba(217,142,115,.35); }

.class-card { background: var(--white); border: 1px solid var(--border); border-radius: var(--r); display: flex; align-items: center; gap: 0; overflow: hidden; margin-bottom: 12px; transition: box-shadow .2s, transform .2s; }
