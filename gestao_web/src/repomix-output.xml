.section { padding: 100px 48px; }
.section-alt { background: var(--bg2); }
.section-tag { font-size: 11px; font-weight: 800; color: var(--pri); letter-spacing: 3px; text-transform: uppercase; margin-bottom: 14px; }
.section-title { font-family: var(--font-display); font-size: 48px; font-weight: 700; line-height: 1.12; margin-bottom: 16px; color: var(--txt); }
.section-sub { font-size: 16px; color: var(--muted); max-width: 500px; margin-bottom: 56px; }
.section-header { text-align: center; margin-bottom: 56px; }
.section-header .section-sub { margin: 0 auto 0; }

.modality-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; max-width: 1040px; margin: 0 auto; }
.modality-card { background: var(--white); border: 1px solid var(--border); border-radius: 24px; padding: 44px; transition: transform .25s, box-shadow .25s; position: relative; overflow: hidden; }
.modality-card::before { content: ''; position: absolute; top: 0; right: 0; width: 200px; height: 200px; border-radius: 50%; background: radial-gradient(circle, var(--accent-fade), transparent 70%); transform: translate(50px,-50px); }
.modality-card.funcional { --accent-fade: rgba(217,142,115,.1); }
.modality-card.danca { --accent-fade: rgba(138,154,91,.1); }
.modality-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,.09); }
.modality-icon { width: 58px; height: 58px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 24px; }
.modality-title { font-family: var(--font-display); font-size: 34px; font-weight: 700; margin-bottom: 14px; }
.modality-desc { color: var(--muted); font-size: 15px; line-height: 1.75; margin-bottom: 32px; }
.schedule-label { font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
.schedule-item { padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 14px; color: var(--txt); }
.schedule-item:last-child { border-bottom: none; }

.plans-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; max-width: 960px; margin: 0 auto; }
.plan-card { background: var(--white); border: 1px solid var(--border); border-radius: 24px; padding: 36px 32px; text-align: center; position: relative; transition: transform .25s, box-shadow .25s; }
.plan-card:hover { transform: translateY(-4px); }
.plan-card.featured { border-color: var(--pri); border-width: 2px; }
.plan-popular { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: var(--pri); color: #fff; padding: 4px 20px; border-radius: var(--r-pill); font-size: 11px; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; white-space: nowrap; }
.plan-name { font-family: var(--font-display); font-size: 26px; font-weight: 700; margin-bottom: 20px; }
.plan-price { display: flex; align-items: baseline; justify-content: center; gap: 4px; margin-bottom: 32px; }
.plan-price-num { font-family: var(--font-display); font-size: 48px; font-weight: 900; }
.plan-price-per { font-size: 14px; color: var(--muted); }
.plan-features { margin-bottom: 32px; text-align: left; }
.plan-feat { display: flex; align-items: flex-start; gap: 10px; padding: 9px 0; border-bottom: 1px solid var(--bg2); font-size: 14px; color: var(--muted); }
.plan-feat:last-child { border-bottom: none; }
.feat-check { color: var(--ok); font-weight: 800; flex-shrink: 0; margin-top: 1px; }

footer { background: var(--bg2); border-top: 1px solid var(--border); padding: 64px 48px 32px; }
.footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
.footer-col-title { font-size: 12px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 18px; }
.footer-link { font-size: 14px; color: var(--muted); display: block; margin-bottom: 10px; cursor: pointer; text-decoration: none; transition: color .2s; }
.footer-link:hover { color: var(--pri); }
.footer-bottom { border-top: 1px solid var(--border); padding-top: 24px; display: flex; justify-content: space-between; align-items: center; }
.footer-copy { font-size: 13px; color: var(--muted); }

.overlay { position: fixed; inset: 0; background: rgba(45,45,45,.65); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 24px; animation: fadeIn .2s ease; }
.modal { background: var(--white); border-radius: 28px; padding: 48px 44px; width: 100%; max-width: 460px; box-shadow: 0 24px 64px rgba(0,0,0,.18); animation: scaleIn .3s cubic-bezier(.34,1.56,.64,1); position: relative; }
.modal-close { position: absolute; top: 18px; right: 20px; background: none; border: none; font-size: 22px; color: var(--muted); cursor: pointer; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: background .2s; }
.modal-close:hover { background: var(--bg); }
.modal-logo { text-align: center; margin-bottom: 36px; }
.modal-logo .logo-mark { width: 56px; height: 56px; margin: 0 auto 16px; font-size: 22px; }
.modal-title { font-family: var(--font-display); font-size: 30px; font-weight: 700; text-align: center; margin-bottom: 6px; }
.modal-sub { font-size: 14px; color: var(--muted); text-align: center; margin-bottom: 36px; }
.forgot-link { display: block; text-align: right; font-size: 13px; color: var(--pri); font-weight: 600; cursor: pointer; margin-top: -10px; margin-bottom: 24px; }
.demo-hint { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r-sm); padding: 10px 14px; font-size: 12px; color: var(--muted); text-align: center; margin-bottom: 20px; }
.demo-hint strong { color: var(--pri); }
.modal-error { background: #FFF5F2; border: 1px solid #FCA5A5; border-radius: var(--r-sm); padding: 12px 16px; font-size: 13px; color: var(--err); font-weight: 600; text-align: center; margin-bottom: 18px; }
.modal-footer { text-align: center; margin-top: 20px; font-size: 14px; color: var(--muted); }
.modal-footer a { color: var(--pri); font-weight: 700; cursor: pointer; }

/* ══════════════════════════════════════════
   DASHBOARD LAYOUT (Blindado contra vazamentos)
══════════════════════════════════════════ */
#page-dashboard { display: flex; height: 100vh; overflow: hidden; }

/* O prefixo impede que essas classes alterem o painel administrativo */
