.hero h1 em { color: var(--pri); font-style: italic; }
.hero-sub { font-size: 16px; color: var(--muted); line-height: 1.8; max-width: 440px; margin-bottom: 48px; }
.hero-btns { display: flex; gap: 14px; align-items: center; margin-bottom: 64px; }
.hero-stats { display: flex; gap: 56px; }
.stat-num { font-family: var(--font-display); font-size: 42px; font-weight: 900; color: var(--pri); line-height: 1; }
