.hero-tag { display: inline-flex; align-items: center; gap: 8px; border: 1.5px solid var(--border); border-radius: var(--r-pill); padding: 7px 18px; margin-bottom: 32px; font-size: 11px; font-weight: 800; color: var(--pri); letter-spacing: 2px; text-transform: uppercase; }
