:is(#page-landing, #page-dashboard) .user-card-plan { font-size: 12px; color: var(--pri); font-weight: 600; }

:is(#page-landing, #page-dashboard) .nav-section { font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); padding: 0 10px; margin-bottom: 8px; margin-top: 8px; }
